# ============================================================
# Fluxure — Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# ---- Required ----

# PostgreSQL connection string
DATABASE_URL=postgresql://fluxure:fluxure_dev@localhost:5432/fluxure
POSTGRES_PASSWORD=fluxure_dev

# JWT Authentication — generate with: openssl rand -hex 32
JWT_SECRET=change-me-run-openssl-rand-hex-64
# Note: JWT_REFRESH_SECRET is NOT used — refresh tokens are opaque hex strings
# (crypto.randomBytes), not signed JWTs. They are looked up by hash in the sessions table.

# Encryption — AES-256-GCM for OAuth tokens at rest
# MUST be exactly 64 hex characters: openssl rand -hex 32
ENCRYPTION_KEY=change-me-run-openssl-rand-hex-32

# Google Calendar OAuth
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# CORS — comma-separated allowed origins
# Split deploy: https://app.fluxure.app,https://fluxure.app
# Self-hosted:  https://yourdomain.com (single origin)
CORS_ORIGIN=http://localhost:5173

# Frontend URL — used for email links and redirects
# Split deploy: https://app.fluxure.app
# Self-hosted:  https://yourdomain.com (same origin as API)
FRONTEND_URL=http://localhost:5173

# ---- Optional ----

# Public API URL — the externally reachable API base (used by frontend/CI)
PUBLIC_API_URL=http://localhost:3000

# Database SSL — set to "true" for production connections (e.g., managed PostgreSQL)
# DATABASE_SSL=true

# PostgreSQL connection pool size (default: 10)
# PG_POOL_MAX=10

# Log level: fatal, error, warn, info, debug, trace (default: info)
# LOG_LEVEL=info

# Webhook base URL — enables Google Calendar push notifications in production
# Leave empty for polling mode in development
WEBHOOK_BASE_URL=

# Redis — required in production for caching, rate limiting, and job queues
# Falls back to in-memory store if not set
REDIS_URL=redis://localhost:6379

# Reverse proxy hop count — set when behind nginx/Cloudflare (e.g., 1)
# Required for accurate rate limiting behind a proxy
TRUST_PROXY=

# Cookie domain — set in production for cross-subdomain cookies (e.g., .yourdomain.com)
# Not required for single-origin deployments
COOKIE_DOMAIN=

# SMTP (email verification, password reset)
# Leave empty to log emails to console in development
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# Stripe Billing (optional — billing disabled if not set)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=

# ---- Self-Hosted Only ----

# Port for the nginx frontend (self-hosted docker-compose only, default: 80)
# FLUXURE_PORT=80

# Environment
NODE_ENV=development
