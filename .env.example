# ============================================================
# Fluxure — Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# ---- Required ----

# PostgreSQL connection string
DATABASE_URL=postgresql://fluxure:fluxure_dev@localhost:5432/fluxure
POSTGRES_PASSWORD=CHANGE_ME_dev_password

# JWT Authentication — generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME

# Encryption — AES-256-GCM for OAuth tokens at rest
# MUST be exactly 64 hex characters: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME

# Google Calendar OAuth
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# CORS — comma-separated allowed origins
# Self-hosted:  https://yourdomain.com (single origin)
CORS_ORIGIN=http://localhost:5173

# Frontend URL — used for email links and redirects
# Self-hosted:  https://yourdomain.com (same origin as API)
FRONTEND_URL=http://localhost:5173

# ---- Optional ----

# Public API URL — the externally reachable API base (used by frontend/CI)
PUBLIC_API_URL=http://localhost:3000

# PostgreSQL connection pool size (default: 10)
# PG_POOL_MAX=10

# Log level: fatal, error, warn, info, debug, trace (default: info)
# LOG_LEVEL=info

# Webhook base URL — enables Google Calendar push notifications when set)
WEBHOOK_BASE_URL=

# Redis — required in production for caching, rate limiting, and job queues
# Falls back to in-memory store if not set
REDIS_URL=redis://localhost:6379

# Redis password — used only by Docker Compose's Redis service (requirepass).
# The API reads Redis auth from the REDIS_URL connection string, not this variable.
# Generated automatically by install.sh
# REDIS_PASSWORD=

# Reverse proxy hop count — set when behind nginx/Cloudflare (e.g., 1)
# Required for accurate rate limiting behind a proxy
TRUST_PROXY=

# Cookie domain — set in production for cross-subdomain cookies (e.g., .yourdomain.com)
# Not required for single-origin deployments
COOKIE_DOMAIN=

# SMTP (email verification, password reset)
# Leave SMTP_HOST empty to log emails to console in development
# SMTP_USER and SMTP_PASS are optional — omit for servers that don't require auth
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# Stripe Billing (optional — billing disabled if not set)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=

# ---- Self-Hosted Only ----

# Grants all users Pro plan limits without Stripe billing
# Set by install.sh — do not set in cloud deployments
# SELF_HOSTED=true

# Port for the Fluxure container (self-hosted, default: 3000)
# FLUXURE_PORT=3000

# Environment
NODE_ENV=development
