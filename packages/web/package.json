{
  "name": "@fluxure/web",
  "version": "1.0.0",
  "private": true,
  "description": "SvelteKit PWA frontend for Fluxure — dashboard, scheduling UI, onboarding, and public booking",
  "license": "AGPL-3.0-only",
  "author": {
    "name": "Joey Manani",
    "email": "contact@theflyingrat.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FluxureCalendar/Fluxure.git",
    "directory": "packages/web"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "lightningcss": "^1.32.0",
    "sass-embedded": "^1.98.0",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.5",
    "typescript": "^5.9.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "jsdom": "^29.0.1",
    "vite": "^7.3.1",
    "vite-plugin-compression2": "^2.5.2",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@fluxure/shared": "workspace:*",
    "@fontsource/geist-mono": "^5.2.7",
    "@fontsource/geist-sans": "^5.2.5",
    "lucide-svelte": "^0.577.0"
  }
}
